{
  "version": 2,
  "builds": [
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/strava/(.*)", "dest": "/api/strava.js" },
    { "src": "/api/coach", "dest": "/api/coach.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
